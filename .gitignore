# Top-level release-branch .gitignore.
# Per-side .gitignore files under llm/ and vlm/ provide additional rules
# scoped to each codebase.

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Build / distribution
build/
dist/
*.egg-info/
.eggs/

# Editor / IDE
.vscode/
.idea/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Notebooks
.ipynb_checkpoints/

# Environment
.env
.venv/
venv/
env/

# Run artifacts
results/
outputs/
output/
logs/
vlmeval_output/

# SLURM stdout/stderr
slurm-*.out
slurm-*.err

# Datasets / model caches
data/
data.zip
qwen_longbench*
.dataset/

# Backup files
*.bak
*.orig

# OS metadata
.DS_Store
Thumbs.db
